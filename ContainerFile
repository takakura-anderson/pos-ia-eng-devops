# Stage 1: Builder — instala dependências em ambiente isolado
FROM public.ecr.aws/docker/library/python:3.13-slim AS builder

WORKDIR /build

COPY requirements.txt .

RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# Stage 2: Runtime — imagem final limpa e segura
FROM public.ecr.aws/docker/library/python:3.13-slim

# Criar usuário não-root para segurança (sintaxe Debian/Ubuntu)
RUN groupadd -r appgroup && useradd -r -g appgroup -m appuser

# Variáveis de ambiente para execução otimizada
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:$PATH"

WORKDIR /app

# Copiar venv do builder (apenas dependências instaladas, sem cache)
COPY --from=builder /opt/venv /opt/venv

# Copiar código fonte, testes e configs
COPY src/ ./src/
COPY tests/ ./tests/
COPY pyproject.toml ./

# Ajustar permissões para que o appuser possa gerar caches locais (.pytest_cache, .ruff_cache)
RUN chown -R appuser:appgroup /app

# Trocar para usuário não-root
USER appuser

# Expor porta da API
EXPOSE 8000

# Iniciar a aplicação FastAPI com uvicorn
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]